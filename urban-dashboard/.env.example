# Copy this file to .env.local and fill in your own values.
# .env.local is git-ignored and must never be committed.

# Google Gemini API key for the policy-assistant agent (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# URL of the FastAPI model backend (see urban-dashboard/backend)
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8000
BACKEND_URL=http://127.0.0.1:8000
